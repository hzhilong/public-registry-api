{
  "name": "public-registry-api",
  "version": "0.0.1",
  "description": "npm 公共注册表 API 的简单封装，带完整的 TypeScript 类型提示",
  "type": "module",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check": "tsc -p tsconfig.dev.json --noEmit && eslint .",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "barrelsby": "barrelsby -c barrelsby.json && import-suffixer \"src/**/*.ts\"",
    "build": "vite build --mode library",
    "npm login": "npm login",
    "npm publish": "npm publish --access public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hzhilong/public-registry-api"
  },
  "bugs": {
    "url": "https://github.com/hzhilong/public-registry-api/issues"
  },
  "homepage": "https://github.com/hzhilong/public-registry-api#readme",
  "keywords": [
    "public-registry-api"
  ],
  "author": "hzhilong",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "barrelsby": "^2.8.1",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "import-suffixer": "^0.0.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.43.0",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4"
  }
}
