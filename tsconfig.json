{
  "compilerOptions": {
    "rootDir": "src",
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "strict": true,
    // 类型导入必须使用 type
    "verbatimModuleSyntax": true,
    // 强制每个文件都是独立可编译的模块
    "isolatedModules": true,
    // 跳过库的声明文件检查
    "skipLibCheck": true,
    // 文件名大小写一致检查
    "forceConsistentCasingInFileNames": true,
    // 允许导入 .ts/.tsx 文件扩展名
    "allowImportingTsExtensions": false,
    // 生成 source map
    "sourceMap": true,
    // 禁用增量编译
    "incremental": false,
  },
  "include": ["src", "*.ts"],
  "exclude": ["node_modules", "dist", ".yalc", "yalc.lock"]
}
